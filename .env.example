# Backend — required
FIREWORKS_API_KEY=
YOUTUBE_API_KEY=
GEMINI_API_KEY=

# --- AI provider selection (content generation / discriminator stages) ---
# Both stages default to "fireworks" with no fallback if unset — leave
# these unset to reproduce the app's original behavior exactly. Set either
# to "amd_vllm" to route that stage through the AMD ROCm/vLLM inference
# service configured below (see amd/README.md to start that service).
# Only content_generation and discriminator are AMD-eligible: both are
# text-only, structured-JSON stages. Vision (Fireworks Kimi multimodal) and
# Gemini vision fallback are untouched by this provider selection.
# CONTENT_GENERATION_PROVIDER=fireworks
# CONTENT_GENERATION_FALLBACK_PROVIDER=fireworks
# DISCRIMINATOR_PROVIDER=fireworks
# DISCRIMINATOR_FALLBACK_PROVIDER=fireworks

# --- AMD GPU inference (ROCm + vLLM OpenAI-compatible server) ---
# Leave unset to run ClipContext with zero AMD configuration — every stage
# above just uses Fireworks. Required only if CONTENT_GENERATION_PROVIDER
# or DISCRIMINATOR_PROVIDER above is set to "amd_vllm". This backend
# process is the only thing that ever talks to this endpoint — never the
# browser. See amd/README.md for how to start the vLLM server on the AMD
# hackathon notebook and what to put here.
# Base URL of the OpenAI-compatible vLLM server, e.g.
# http://<notebook-host>:8000/v1 or a tunnel URL — never a browser-facing
# origin.
AMD_VLLM_BASE_URL=
# Model id vLLM was started with (must match --served-model-name exactly).
AMD_VLLM_MODEL=
# Only required if the vLLM server was started with --api-key.
AMD_VLLM_API_KEY=
# Request timeout in seconds for AMD vLLM calls. Increase if the notebook
# GPU is slow to warm up on the first request after a cold start.
# AMD_VLLM_TIMEOUT_SECONDS=60

# Backend — optional (sane defaults applied if unset)
# Comma-separated list of origins allowed to call the API (CORS).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Maximum accepted video upload size, in megabytes.
MAX_UPLOAD_SIZE_MB=200
# Port the FastAPI server binds to.
PORT=8000

# --- YouTube OAuth ("Connect with YouTube" / "Upload to YouTube") ---
# Leave these unset to run ClipContext without the YouTube feature — every
# other part of the app works fine. GET /api/youtube/connect returns a
# structured 503 (YOUTUBE_OAUTH_NOT_CONFIGURED) until all three are set.
# Create these in Google Cloud Console > APIs & Services > Credentials
# (OAuth client ID, type "Web application"). See README.md for the full
# walkthrough, including the exact redirect URI to register.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match a "Authorized redirect URI" on the OAuth client, and
# must point at this backend's own /api/youtube/callback route.
# Local dev default: http://localhost:8000/api/youtube/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/youtube/callback
# Where the backend sends the browser after the OAuth callback completes
# (appends "/results?youtube=connected" or "?youtube=error&code=...").
FRONTEND_URL=http://localhost:3000
# Space- or comma-separated OAuth scopes. Defaults to youtube.upload plus
# youtube.readonly — the upload scope alone is rejected by channels.list
# (mine=true), which the app needs to show the connected channel's name.
# GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/youtube.upload https://www.googleapis.com/auth/youtube.readonly
# Session cookie behavior. For local http dev, leave both unset (defaults
# below). For a production deployment where the frontend and backend are on
# different origins, set COOKIE_SAMESITE=none and COOKIE_SECURE=true (both
# are required together — browsers reject SameSite=None without Secure).
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax

# --- ClipContext accounts (Firebase Authentication + Firestore) ---
# Separate from GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET above, which
# authorize YouTube uploads — not a ClipContext account login. See
# README.md "Connect with YouTube vs. ClipContext accounts" for why these
# are intentionally two different systems.
#
# Leave these unset to run ClipContext without accounts — upload, process,
# results, and YouTube upload all keep working. Account endpoints
# (POST/GET/DELETE /api/artifacts) return a structured 503
# (FIREBASE_NOT_CONFIGURED) until FIREBASE_PROJECT_ID is set.
FIREBASE_PROJECT_ID=
# Firebase Admin credentials — use exactly ONE of the following two, never
# both. See README.md for how to obtain a service account.
# 1) Path to a service-account JSON file (gitignored, never commit it):
GOOGLE_APPLICATION_CREDENTIALS=
# 2) OR the service-account JSON inline, for hosts that only support
#    environment variables (no file mounts). Leave (1) unset if using this.
# FIREBASE_SERVICE_ACCOUNT_JSON=
# If both are unset and the backend itself runs on Google Cloud (Cloud Run,
# GCE, GKE) with an attached service account, Application Default
# Credentials are used automatically — no explicit credential needed there.

# Frontend — required for the Next.js app to reach the backend.
# Set this in frontend/.env.local (see frontend/.env.local.example).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Frontend — Firebase web config (ClipContext account login). Not a server
# secret (it ships in the deployed JS bundle by design — Firebase access
# control lives in Auth + Firestore rules, not in hiding this config), but
# still environment-specific. Set in frontend/.env.local. Leave unset to
# run ClipContext without accounts.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
